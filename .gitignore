# ---- Terraform ----
# Local .terraform directories
**/.terraform/*
.terraform.lock.hcl

# State files (never commit; use remote backend)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Plan output files
*.tfplan
*.plan

# Variable files that may contain secrets
*.tfvars
*.tfvars.json
!example.tfvars

# CLI configuration / override files
.terraformrc
terraform.rc
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ---- Go ----
# Compiled binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/
dist/

# Test binary and coverage
*.test
*.out
coverage.*
*.cover

# Go workspace file
go.work
go.work.sum

# Dependency directory (if vendoring not committed)
# vendor/

# ---- Editors / OS ----
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---- Misc ----
*.log
.env
.env.*
!.env.example
